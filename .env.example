# Copy to .env and fill in real values. docker-compose reads this for the backend.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Small/fast model used for metadata inference.
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=atlas-people-context-uploader
# Optional: override the derived endpoint (https://<account_id>.r2.cloudflarestorage.com)
# R2_ENDPOINT_URL=

# --- App ---
# Comma-separated origins allowed by CORS (frontend dev servers).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
